# FHIR server credentials (used by the backend proxy, not the frontend)
FHIR_BASE_URL=https://your-instance.medblocks.app/fhir
FHIR_BEARER_TOKEN=your-token-here
PORT=8787

# Groq API key, used by POST /api/summary/:patientId to generate the
# AI-assisted clinical summary (model: openai/gpt-oss-120b)
GROQ_API_KEY=your-groq-api-key-here
